// hooks/hooks.json — uye plugin hook configuration (JSONC)
// Hook types: "command" | "prompt" | "agent"
// Scripts must be executable: chmod +x scripts/hooks/<name>.sh
// Use ${CLAUDE_PLUGIN_ROOT} for all paths inside hook commands.
{
  "hooks": {

    // Runs ruff format + ruff check --fix after Claude writes or edits a Python file.
    // Requires: ruff (pip install ruff). Exits silently if ruff is not installed.
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/format-python.sh"
          }
        ]
      }
    ]

